{
  "name": "sia-stock-score-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "check": "npm run typecheck && npm run build",
    "deploy:preview": "bash scripts/vercel_preview_deploy.sh",
    "start": "next start",
    "lint": "tsc --noEmit",
    "score:smoke": "${PYTHON_BIN:-python} scripts/score_smoke_check.py",
    "snapshots:drain": "${PYTHON_BIN:-python} scripts/publish_stock_snapshots.py --drain-queue --json",
    "test": "node --import tsx --test \"tests/**/*.test.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "lightweight-charts": "^5.2.0",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.0"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
