{
  "name": "sia-stock-score-next",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "check": "npm run typecheck && npm run build",
    "check:all": "npm test && npm run test:python && npm run test:rust && npm run check",
    "deploy:preview": "bash scripts/vercel_preview_deploy.sh",
    "industry:audit": "bash scripts/run_python.sh scripts/industry_quality_audit.py --json",
    "start": "next start",
    "lint": "tsc --noEmit",
    "market-calendar:sync": "bash scripts/run_python.sh scripts/sync_market_calendar.py",
    "ops:report": "bash scripts/run_python.sh scripts/stock_operations_report.py --json",
    "score:smoke": "bash scripts/run_python.sh scripts/score_smoke_check.py",
    "snapshots:drain": "bash scripts/run_python.sh scripts/publish_stock_snapshots.py --drain-queue --json",
    "supabase:readiness": "bash scripts/run_python.sh scripts/supabase_runtime_readiness.py --json",
    "test": "node --import tsx --test \"tests/**/*.test.ts\"",
    "test:python": "bash scripts/run_python.sh -m unittest discover tests",
    "test:rust": "cargo test --manifest-path services/market-data/Cargo.toml",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "lightweight-charts": "^5.2.0",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.0"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
